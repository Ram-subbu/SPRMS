{
  "ConnectionStrings": {
    "Default": "Server=STAGING_SERVER;Database=SPRMS_V1;User Id=app_user;Password=${DB_PASSWORD};Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true;Application Name=SPRMS_API",
    "DefaultConnection": "Server=STAGING_SERVER;Database=SPRMS_V1;User Id=app_user;Password=${DB_PASSWORD};Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true;Application Name=SPRMS_API",
    "Redis": "staging-redis-server:6379,password=${REDIS_PASSWORD},ssl=true,abortConnect=false"
  },
  "JWT": {
    "Secret": "${JWT_SECRET}"
  },
  "AllowedOrigins": {
    "React": "https://staging.sprms.rcsc.gov.bt",
    "Prod": "https://staging.sprms.rcsc.gov.bt"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
