{
  "ConnectionStrings": {
    "Default": "Server=PROD_SQL_SERVER;Database=SPRMS_V1;User Id=sprms_app;Password=${DB_PASSWORD};Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true;Application Name=SPRMS_API",
    "DefaultConnection": "Server=PROD_SQL_SERVER;Database=SPRMS_V1;User Id=sprms_app;Password=${DB_PASSWORD};Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true;Application Name=SPRMS_API",
    "Redis": "prod-redis.yourdomain.com:6379,password=${REDIS_PASSWORD},ssl=true,abortConnect=false"
  },
  "JWT": {
    "Secret": "${JWT_SECRET}"
  },
  "AllowedOrigins": {
    "React": "https://sprms.rcsc.gov.bt",
    "Prod": "https://sprms.rcsc.gov.bt"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Error",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.EntityFrameworkCore": "Error"
      }
    }
  }
}
