          "applicationID": {
            "type": "integer",
            "format": "int64"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "paymentMethod": {
            "type": "string",
            "nullable": true
          },
          "accountNumber": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateProgramRequest": {
        "type": "object",
        "properties": {
          "programName": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "applicationDeadline": {
            "type": "string",
            "format": "date-time"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "maxApplications": {
            "type": "integer",
            "format": "int32"
          },
          "awardPerStudent": {
            "type": "number",
            "format": "double"
          },
          "minGPA": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EvaluateApplicationRequest": {
        "type": "object",
        "properties": {
          "applicationID": {
            "type": "integer",
            "format": "int64"
          }
        },
        "additionalProperties": false
