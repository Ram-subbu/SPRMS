        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Status": {
        "enum": [
          "Inactive",
          "Active",
          "Closed",
          "Submitted",
          "UnderReview",
          "Approved",
          "Rejected",
          "Withdrawn",
          "PendingFO",
          "Pending",
          "PendingDecision",
